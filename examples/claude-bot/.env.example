# Copy this to .env and fill in your values. Never commit .env.

# Required — your Anthropic API key
ANTHROPIC_API_KEY=sk-ant-...

# Required — the deployed PartyKit host (no scheme; SDK adds ws:// or wss://)
PARTYKIT_HOST=flushem.jesse-stewart.partykit.dev
# For local development:
# PARTYKIT_HOST=localhost:1999

# Required — which room to join. Room IDs are 6 characters (the join form caps at 6).
ROOM_ID=CLAUDE

# Optional — room password (set or match)
# ROOM_PASSWORD=

# Optional — overrides for the bot's identity
BOT_NAME=Claude
# BOT_ID=mybot-1

# Optional — auto-add CPU bots when entering a fresh lobby.
# Comma-separated list of difficulties (easy|medium|hard); one entry = one CPU.
# E.g. EXTRA_BOTS=easy,hard,medium adds three CPUs (one of each difficulty).
# Capped to 3 entries (the room's 4-player limit minus this bot). Empty = off.
# EXTRA_BOTS=easy,hard
