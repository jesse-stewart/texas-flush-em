# Copy this to .env and fill in your values. Never commit .env.

# Required — your Anthropic API key
ANTHROPIC_API_KEY=sk-ant-...

# Required — the deployed PartyKit host (no scheme; SDK adds ws:// or wss://)
PARTYKIT_HOST=flushem.jesse-stewart.partykit.dev
# For local development:
# PARTYKIT_HOST=localhost:1999

# Required — which room to join. Room IDs are 6 characters (the join form caps at 6).
ROOM_ID=CLAUDE

# Optional — room password (set or match)
# ROOM_PASSWORD=

# Optional — overrides for the bot's identity
BOT_NAME=Claude
# BOT_ID=mybot-1

# Optional — auto-add CPU bots when entering a fresh lobby.
# Comma-separated list of difficulties (easy|medium|hard); one entry = one CPU.
# E.g. EXTRA_BOTS=easy,hard,medium adds three CPUs (one of each difficulty).
# Capped to 3 entries (the room's 4-player limit minus this bot). Empty = off.
# EXTRA_BOTS=easy,hard

# Optional — auto-start the game from the lobby once at least 2 players are seated.
# The bot waits AUTO_START_DELAY_MS first to give humans time to join and any
# extra bots time to register on the server. Set both for a fully unattended run.
# AUTO_START=true
# AUTO_START_DELAY_MS=3000

# Optional — Claude API tuning. Defaults are tuned for cost (Sonnet 4.6 + medium + no thinking),
# which is plenty for solid play. Crank these up if you want stronger strategic play; back them
# down for cheaper runs.
#
# Cost ladder (rough, per call):
#   Cheap:    sonnet-4-6 + low    + off         ← cheapest, weaker plays
#   Default:  sonnet-4-6 + medium + off         ← balanced (current default)
#   Premium:  opus-4-7   + high   + summarized  ← strongest plays, ~10× more expensive
#
# CLAUDE_MODEL=claude-sonnet-4-6
# CLAUDE_EFFORT=medium
# CLAUDE_THINKING=off              # off | quiet | summarized
# CLAUDE_MAX_TOKENS=8000
